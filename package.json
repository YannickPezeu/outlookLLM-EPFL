{
  "name": "outlook-llm-epfl",
  "version": "0.1.0",
  "description": "Outlook Add-in for EPFL - Email summarization and organization powered by RCP LLM API",
  "private": true,
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:ghpages": "webpack --mode production --env ghpages",
    "start": "webpack serve --mode development --https",
    "lint": "eslint src/**/*.{ts,tsx}",
    "sideload": "npx office-addin-dev-certs install && webpack serve --mode development --https"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.6.0",
    "@fluentui/react-components": "^9.46.0",
    "@fluentui/react-icons": "^2.0.230",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/office-js": "^1.0.377",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.9.1",
    "html-webpack-plugin": "^5.6.0",
    "office-addin-dev-certs": "^1.13.2",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.2"
  }
}
