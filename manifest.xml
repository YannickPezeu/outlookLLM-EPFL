<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- BEGIN: Add-in metadata -->
  <Id>e4e7f5a0-1234-4abc-9def-000000000001</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>EPFL</ProviderName>
  <DefaultLocale>fr-FR</DefaultLocale>
  <DisplayName DefaultValue="EPFL Mail AI" />
  <Description DefaultValue="Préparation de réunions et résumé d'emails avec l'IA - Propulsé par RCP EPFL" />
  <IconUrl DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/assets/icon-64.png" />
  <HighResolutionIconUrl DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://github.com/YannickPezeu/outlookLLM-EPFL" />
  <!-- END: Add-in metadata -->

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>

  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ReadWriteItem needed for AppointmentOrganizerCommandSurface extension point -->
  <Permissions>ReadWriteItem</Permissions>

  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
    <Rule xsi:type="ItemIs" ItemType="Appointment" FormType="Read" />
  </Rule>

  <DisableEntityHighlighting>false</DisableEntityHighlighting>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Requirements>
      <bt:Sets DefaultMinVersion="1.5">
        <bt:Set Name="Mailbox" />
      </bt:Sets>
    </Requirements>

    <Hosts>
      <Host xsi:type="MailHost">
        <DesktopFormFactor>
          <!-- Extension point: button in the reading pane -->
          <ExtensionPoint xsi:type="MessageReadCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="epflMailAiGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="openTaskPaneBtn">
                  <Label resid="TaskPaneBtn.Label" />
                  <Supertip>
                    <Title resid="TaskPaneBtn.Label" />
                    <Description resid="TaskPaneBtn.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskPane.Url" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Extension point: calendar event — when user is an attendee -->
          <ExtensionPoint xsi:type="AppointmentAttendeeCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="epflMailAiAttendeeGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="openTaskPaneAttendeeBtn">
                  <Label resid="TaskPaneBtn.Label" />
                  <Supertip>
                    <Title resid="TaskPaneBtn.Label" />
                    <Description resid="TaskPaneBtn.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskPane.Url" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>

          <!-- Extension point: calendar event — when user is the organizer -->
          <ExtensionPoint xsi:type="AppointmentOrganizerCommandSurface">
            <OfficeTab id="TabDefault">
              <Group id="epflMailAiOrganizerGroup">
                <Label resid="GroupLabel" />
                <Control xsi:type="Button" id="openTaskPaneOrganizerBtn">
                  <Label resid="TaskPaneBtn.Label" />
                  <Supertip>
                    <Title resid="TaskPaneBtn.Label" />
                    <Description resid="TaskPaneBtn.Tooltip" />
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16" />
                    <bt:Image size="32" resid="Icon.32x32" />
                    <bt:Image size="80" resid="Icon.80x80" />
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <SourceLocation resid="TaskPane.Url" />
                    <SupportsPinning>true</SupportsPinning>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>

    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/assets/icon-16.png" />
        <bt:Image id="Icon.32x32" DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/assets/icon-32.png" />
        <bt:Image id="Icon.80x80" DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/assets/icon-80.png" />
      </bt:Images>
      <bt:Urls>
        <bt:Url id="TaskPane.Url" DefaultValue="https://yannickpezeu.github.io/outlookLLM-EPFL/taskpane.html" />
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GroupLabel" DefaultValue="EPFL Mail AI" />
        <bt:String id="TaskPaneBtn.Label" DefaultValue="EPFL Mail AI" />
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="TaskPaneBtn.Tooltip" DefaultValue="Ouvrir l'assistant IA pour préparer vos réunions et résumer vos emails" />
      </bt:LongStrings>
    </Resources>
  </VersionOverrides>
</OfficeApp>
